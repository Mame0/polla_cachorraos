---
import Layout from '../layouts/Layout.astro';
import { pot, formatMoney, formatDate } from '../lib/helpers';

const { supabase, user, profile } = Astro.locals;
if (!user) return Astro.redirect('/login?msg=Inicia sesión');
if (profile?.role !== 'tesorero' && profile?.role !== 'admin') return Astro.redirect('/');

const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');

// Pollas con sus inscritos y estado de pago.
const { data: pollData } = await supabase
  .from('polls')
  .select('id, name, entry_amount, creator:profiles!created_by(username), poll_members(user_id, paid, paid_at, profiles(username))')
  .order('created_at', { ascending: false });

type Member = { user_id: string; paid: boolean; paid_at: string | null; profiles: { username: string } | null };
type PollRow = { id: string; name: string; entry_amount: number; creator: { username: string } | null; poll_members: Member[] };
const polls = ((pollData as any[]) ?? []) as PollRow[];

// Usuarios registrados.
const { data: profData } = await supabase
  .from('profiles')
  .select('username, role, created_at')
  .order('created_at', { ascending: true });
const users = (profData as { username: string; role: string; created_at: string }[]) ?? [];
---

<Layout title="Tesorero · Polla Cachorraos">
  <h1 class="animate-rise text-2xl font-black text-polla-blue sm:text-3xl">Panel del tesorero</h1>
  <p class="mt-1 text-sm text-gray-500">Marca quién ya pagó en cada polla.</p>

  {saved && <p class="mt-4 rounded-lg bg-polla-green-light px-4 py-3 text-sm text-polla-green">✅ {saved}</p>}
  {error && <p class="mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{error}</p>}

  <!-- Pollas y pagos -->
  <h2 class="mt-8 text-lg font-bold text-gray-800">Pollas y pagos</h2>
  {polls.length === 0 ? (
    <p class="mt-3 rounded-xl border border-dashed border-gray-300 bg-white p-6 text-center text-gray-500">
      Todavía no hay pollas creadas.
    </p>
  ) : (
    <div class="mt-3 space-y-5">
      {polls.map((p) => {
        const members = p.poll_members ?? [];
        const paidCount = members.filter((m) => m.paid).length;
        const recaudado = paidCount * p.entry_amount;
        const bote = pot(p.entry_amount, members.length);
        return (
          <section class="card p-5">
            <div class="flex flex-wrap items-center justify-between gap-2">
              <div>
                <h3 class="font-bold text-polla-blue">{p.name}</h3>
                <p class="text-xs text-gray-400">por {p.creator?.username ?? '—'} · {formatMoney(p.entry_amount)} c/u</p>
              </div>
              <div class="text-right text-sm">
                <p class="font-bold text-polla-green">Recaudado {formatMoney(recaudado)}</p>
                <p class="text-xs text-gray-500">de {formatMoney(bote)} · {paidCount}/{members.length} pagaron</p>
              </div>
            </div>

            <div class="mt-3 divide-y divide-gray-100 overflow-hidden rounded-xl border border-gray-200">
              {members.length === 0 && (
                <p class="px-4 py-3 text-sm text-gray-400">Nadie se ha inscrito todavía.</p>
              )}
              {members.map((m) => (
                <div class="flex items-center justify-between gap-3 px-4 py-2.5">
                  <span class="flex items-center gap-2 text-sm">
                    <span class="font-medium">{m.profiles?.username ?? '—'}</span>
                    {m.paid ? (
                      <span class="rounded-full bg-polla-green-light px-2 py-0.5 text-xs font-semibold text-polla-green">Pagado</span>
                    ) : (
                      <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">Pendiente</span>
                    )}
                  </span>
                  <form method="POST" action="/api/tesorero/toggle-paid">
                    <input type="hidden" name="poll_id" value={p.id} />
                    <input type="hidden" name="user_id" value={m.user_id} />
                    <input type="hidden" name="paid" value={(!m.paid).toString()} />
                    {m.paid ? (
                      <button class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50">
                        Marcar pendiente
                      </button>
                    ) : (
                      <button class="btn-shine rounded-xl bg-polla-green px-3 py-1.5 text-sm font-semibold text-white shadow-sm transition hover:brightness-110">
                        Marcar pagado
                      </button>
                    )}
                  </form>
                </div>
              ))}
            </div>
          </section>
        );
      })}
    </div>
  )}

  <!-- Usuarios registrados -->
  <h2 class="mt-10 text-lg font-bold text-gray-800">Usuarios registrados ({users.length})</h2>
  <div class="card mt-3 overflow-x-auto p-0">
    <table class="w-full text-sm">
      <thead>
        <tr class="bg-brand text-left text-white">
          <th class="px-4 py-3">Usuario</th>
          <th class="px-4 py-3">Rol</th>
          <th class="px-4 py-3">Registrado</th>
        </tr>
      </thead>
      <tbody>
        {users.map((u, i) => (
          <tr class={`border-t border-gray-100 ${i % 2 ? 'bg-gray-50/50' : ''}`}>
            <td class="px-4 py-3 font-medium">{u.username}</td>
            <td class="px-4 py-3 text-gray-600">{u.role}</td>
            <td class="px-4 py-3 text-gray-500">{formatDate(u.created_at)}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</Layout>
