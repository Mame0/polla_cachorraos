---
import Layout from '../layouts/Layout.astro';
import { formatDate, pointsBadge, statusLabel, type Match, type Prediction } from '../lib/helpers';

const { supabase, user } = Astro.locals;
if (!user) return Astro.redirect('/login?msg=Inicia sesión para ver tus pronósticos');

// Pronósticos del usuario con su partido y su polla (join)
const { data } = await supabase
  .from('predictions')
  .select('*, matches(*), polls(id, name)')
  .eq('user_id', user.id);

type Row = Prediction & { matches: Match; polls: { id: string; name: string } | null };
const rows = ((data as Row[]) ?? []).sort(
  (a, b) => new Date(b.matches.match_date).getTime() - new Date(a.matches.match_date).getTime()
);

const finished = rows.filter((r) => r.matches.status === 'finished');
const totalPoints = rows.reduce((s, r) => s + r.points_earned, 0);
const exact = finished.filter((r) => r.points_earned === 5).length;
const hitRate = finished.length ? Math.round((finished.filter((r) => r.points_earned > 0).length / finished.length) * 100) : 0;
---

<Layout title="Mis pronósticos · Polla Mundialista">
  <h1 class="text-2xl font-extrabold text-polla-blue">Mis pronósticos</h1>

  <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-4">
    <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-polla-green">{totalPoints}</p>
      <p class="text-xs text-gray-500">Puntos</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-polla-blue">{rows.length}</p>
      <p class="text-xs text-gray-500">Pronósticos</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-yellow-600">{exact}</p>
      <p class="text-xs text-gray-500">Exactos</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-gray-700">{hitRate}%</p>
      <p class="text-xs text-gray-500">Aciertos</p>
    </div>
  </div>

  {rows.length === 0 ? (
    <p class="mt-6 rounded-xl border border-dashed border-gray-300 bg-white p-6 text-center text-gray-500">
      Aún no has hecho pronósticos. <a href="/" class="font-semibold text-polla-blue hover:underline">Únete a una polla</a>.
    </p>
  ) : (
    <div class="mt-6 space-y-2">
      {rows.map((r) => {
        const m = r.matches;
        const isFinished = m.status === 'finished';
        const badge = isFinished ? pointsBadge(r.points_earned) : null;
        return (
          <div class="flex flex-wrap items-center justify-between gap-3 rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
            <div>
              <div class="font-semibold">{m.home_team} vs {m.away_team}</div>
              <div class="text-xs text-gray-400">
                {r.polls ? <a href={`/polla/${r.polls.id}`} class="font-medium text-polla-blue hover:underline">{r.polls.name}</a> : '—'}
                · {statusLabel[m.status]} · {formatDate(m.match_date)}
              </div>
            </div>
            <div class="flex items-center gap-4 text-sm">
              <div class="text-center">
                <div class="text-xs text-gray-400">Tu pronóstico</div>
                <div class="font-bold">{r.home_score} – {r.away_score}</div>
              </div>
              {isFinished && (
                <div class="text-center">
                  <div class="text-xs text-gray-400">Real</div>
                  <div class="font-bold">{m.home_score} – {m.away_score}</div>
                </div>
              )}
              {badge && <span class={`rounded-full px-3 py-1 text-xs font-semibold ${badge.classes}`}>{badge.label}</span>}
            </div>
          </div>
        );
      })}
    </div>
  )}
</Layout>
