---
import Layout from '../layouts/Layout.astro';
import { formatDate, dayKey, dayLabel, todayKey, getTeamFlagUrl, type Match } from '../lib/helpers';

const { supabase, user } = Astro.locals;
if (!user) return Astro.redirect('/login?msg=Inicia sesión para crear una polla');

const error = Astro.url.searchParams.get('error');

// Partidos seleccionables: próximos y desde hoy en adelante (UTC-5).
const today = todayKey();
const { data: matchData } = await supabase
  .from('matches')
  .select('*')
  .eq('status', 'upcoming')
  .order('match_date', { ascending: true });
const matches = ((matchData as Match[]) ?? []).filter((m) => dayKey(m.match_date) >= today);

// Agrupar por día para mostrarlos ordenados.
const groups = new Map<string, Match[]>();
for (const m of matches) {
  const k = dayKey(m.match_date);
  if (!groups.has(k)) groups.set(k, []);
  groups.get(k)!.push(m);
}
---

<Layout title="Crear polla · Polla Cachorraos">
  <a href="/" class="text-sm font-semibold text-polla-blue hover:underline">← Volver al inicio</a>
  <h1 class="mt-2 text-2xl font-extrabold text-polla-blue">Crear una polla</h1>
  <p class="mt-1 text-sm text-gray-500">
    Elige los partidos, define el monto por persona y comparte la polla con tus amigos.
  </p>

  {error && <p class="mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{error}</p>}

  {matches.length === 0 ? (
    <p class="mt-6 rounded-xl border border-dashed border-gray-300 bg-white p-6 text-center text-gray-500">
      No hay partidos próximos disponibles para armar una polla.
    </p>
  ) : (
    <form method="POST" action="/api/polls/create" class="mt-6 space-y-6">
      <div class="sticky top-0 z-10 -mx-4 grid gap-4 border-b border-gray-200 bg-gray-50/95 px-4 py-3 backdrop-blur sm:grid-cols-[1fr_auto_auto] sm:items-end">
        <div>
          <label class="block text-sm font-semibold text-gray-700">Nombre de la polla</label>
          <input
            type="text" name="name" required maxlength="60"
            placeholder="Ej. Polla del jueves"
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30"
          />
        </div>
        <div>
          <label class="block text-sm font-semibold text-gray-700">Monto por persona (S/)</label>
          <input
            type="number" name="entry_amount" min="0" step="1" value="0"
            class="mt-1 w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30 sm:w-36"
          />
        </div>
        <button class="rounded-lg bg-polla-green px-6 py-2 text-sm font-semibold text-white transition hover:brightness-110">
          Crear polla
        </button>
      </div>

      <div>
        <h2 class="text-sm font-bold uppercase tracking-wide text-gray-400">Partidos</h2>
        <p class="text-xs text-gray-500">Marca los partidos que entran en la polla.</p>

        {[...groups.entries()].map(([k, groupMatches]) => (
          <section class="mt-4">
            <h3 class="mb-2 text-sm font-semibold capitalize text-gray-600">{dayLabel(groupMatches[0].match_date)}</h3>
            <div class="space-y-2">
              {groupMatches.map((m) => {
                const homeFlag = getTeamFlagUrl(m.home_team);
                const awayFlag = getTeamFlagUrl(m.away_team);
                return (
                  <label class="flex cursor-pointer items-center gap-3 rounded-xl border border-gray-200 bg-white p-3 shadow-sm transition hover:border-polla-blue/50">
                    <input type="checkbox" name="match_ids" value={m.id} class="h-4 w-4 accent-polla-green" />
                    <span class="flex-1 flex flex-wrap items-center gap-1.5 font-medium">
                      {homeFlag && <img src={homeFlag} class="h-3.5 w-5 rounded border border-gray-100 object-cover shadow-xs" alt="" />}
                      <span>{m.home_team}</span>
                      <span class="text-gray-400 font-normal">vs</span>
                      {awayFlag && <img src={awayFlag} class="h-3.5 w-5 rounded border border-gray-100 object-cover shadow-xs" alt="" />}
                      <span>{m.away_team}</span>
                    </span>
                    <span class="text-xs text-gray-400">{formatDate(m.match_date)}</span>
                  </label>
                );
              })}
            </div>
          </section>
        ))}
      </div>
    </form>
  )}
</Layout>
