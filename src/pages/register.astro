---
import Layout from '../layouts/Layout.astro';

if (Astro.locals.user) return Astro.redirect('/');

const error = Astro.url.searchParams.get('error');
---

<Layout title="Registro · Polla Mundialista">
  <div class="animate-rise mx-auto max-w-md">
    <div class="card overflow-hidden">
      <div class="bg-brand px-8 py-7 text-white">
        <div class="text-3xl">⚽</div>
        <h1 class="mt-2 text-2xl font-black">Crear cuenta</h1>
        <p class="mt-1 text-sm text-white/80">Únete a la polla y compite con tu grupo.</p>
      </div>
      <div class="p-8 pt-6">

      {error && (
        <p class="mb-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{error}</p>
      )}

      <form method="POST" action="/api/auth/register" class="space-y-4">
        <div>
          <label class="mb-1 block text-sm font-medium" for="username">Nombre de usuario</label>
          <input id="username" name="username" type="text" required minlength="3" maxlength="20"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium" for="email">Email</label>
          <input id="email" name="email" type="email" required autocomplete="email"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
        </div>
        <div>
          <label class="mb-1 block text-sm font-medium" for="password">Contraseña (mín. 8)</label>
          <input id="password" name="password" type="password" required minlength="8" autocomplete="new-password"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
        </div>
        <button class="btn-shine w-full rounded-xl bg-polla-green py-2.5 font-semibold text-white shadow-md shadow-pino/20 transition hover:brightness-110">
          Crear cuenta
        </button>
      </form>

      <p class="mt-6 text-center text-sm text-gray-500">
        ¿Ya tienes cuenta?
        <a href="/login" class="font-semibold text-azul-real hover:underline">Inicia sesión</a>
      </p>
      </div>
    </div>
  </div>
</Layout>
