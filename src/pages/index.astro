---
import Layout from '../layouts/Layout.astro';
import { pot, formatMoney, type Poll } from '../lib/helpers';

const { supabase, user, profile } = Astro.locals;

const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');

type PollCard = Poll & { creator: { username: string } | null; member_count: number; is_member: boolean };
let myPolls: PollCard[] = [];
let openPolls: PollCard[] = [];

if (user) {
  const [{ data: pollData }, { data: memberData }] = await Promise.all([
    supabase.from('polls').select('*, creator:profiles!created_by(username)').order('created_at', { ascending: false }),
    supabase.from('poll_members').select('poll_id, user_id'),
  ]);

  const members = (memberData as any[]) ?? [];
  const countByPoll = new Map<string, number>();
  const mine = new Set<string>();
  for (const m of members) {
    countByPoll.set(m.poll_id, (countByPoll.get(m.poll_id) ?? 0) + 1);
    if (m.user_id === user.id) mine.add(m.poll_id);
  }

  const cards: PollCard[] = ((pollData as any[]) ?? []).map((p) => ({
    ...(p as Poll),
    creator: p.creator ?? null,
    member_count: countByPoll.get(p.id) ?? 0,
    is_member: mine.has(p.id),
  }));

  myPolls = cards.filter((p) => p.is_member);
  openPolls = cards.filter((p) => !p.is_member);
}
---

<Layout title="Inicio · Polla Cachorraos">
  {!user ? (
    <section class="mx-auto max-w-2xl rounded-2xl border border-gray-200 bg-white p-10 text-center shadow-sm">
      <div class="text-6xl">⚽</div>
      <h1 class="mt-4 text-3xl font-extrabold text-polla-blue">Polla Cachorraos</h1>
      <p class="mx-auto mt-3 max-w-md text-gray-600">
        Crea pollas con tus amigos, elige los partidos del día, pon el monto y compite por el bote.
      </p>
      <div class="mt-6 flex justify-center gap-3">
        <a href="/register" class="rounded-lg bg-polla-green px-6 py-3 font-semibold text-white transition hover:brightness-110">
          Empezar ahora
        </a>
        <a href="/login" class="rounded-lg border border-gray-300 px-6 py-3 font-semibold text-gray-700 transition hover:bg-gray-50">
          Entrar
        </a>
      </div>
      <div class="mt-8 grid grid-cols-2 gap-3 text-sm sm:grid-cols-4">
        <div class="rounded-lg bg-polla-green-light p-3"><strong class="block text-lg text-polla-green">5</strong> Exacto</div>
        <div class="rounded-lg bg-polla-blue-light p-3"><strong class="block text-lg text-polla-blue">3</strong> Diferencia</div>
        <div class="rounded-lg bg-yellow-100 p-3"><strong class="block text-lg text-yellow-700">2</strong> Ganador</div>
        <div class="rounded-lg bg-gray-100 p-3"><strong class="block text-lg text-gray-500">0</strong> Falla</div>
      </div>
    </section>
  ) : (
    <section>
      <div class="flex flex-wrap items-center justify-between gap-3">
        <h1 class="text-2xl font-extrabold text-polla-blue">Hola, {profile?.username} 👋</h1>
        <a href="/crear-polla" class="rounded-lg bg-polla-green px-5 py-2.5 text-sm font-semibold text-white transition hover:brightness-110">
          + Crear polla
        </a>
      </div>

      {saved && <p class="mt-4 rounded-lg bg-polla-green-light px-4 py-3 text-sm text-polla-green">✅ {saved}</p>}
      {error && <p class="mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{error}</p>}

      <h2 class="mt-8 text-lg font-bold text-gray-800">Mis pollas</h2>
      {myPolls.length === 0 ? (
        <p class="mt-3 rounded-xl border border-dashed border-gray-300 bg-white p-6 text-center text-gray-500">
          Aún no participas en ninguna polla. Crea una o únete a las disponibles.
        </p>
      ) : (
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          {myPolls.map((p) => (
            <a href={`/polla/${p.id}`} class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm transition hover:border-polla-blue/50 hover:shadow">
              <div class="flex items-center justify-between gap-2">
                <h3 class="font-bold text-polla-blue">{p.name}</h3>
                <span class="rounded-full bg-polla-green-light px-2 py-0.5 text-xs font-semibold text-polla-green">Inscrito</span>
              </div>
              <p class="mt-1 text-xs text-gray-400">por {p.creator?.username ?? '—'}</p>
              <div class="mt-3 flex items-center justify-between text-sm">
                <span class="text-gray-500">{p.member_count} jugadores</span>
                <span class="font-semibold text-gray-700">Bote {formatMoney(pot(p.entry_amount, p.member_count))}</span>
              </div>
            </a>
          ))}
        </div>
      )}

      <h2 class="mt-10 text-lg font-bold text-gray-800">Pollas disponibles</h2>
      {openPolls.length === 0 ? (
        <p class="mt-3 rounded-xl border border-dashed border-gray-300 bg-white p-6 text-center text-gray-500">
          No hay otras pollas por ahora.
        </p>
      ) : (
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          {openPolls.map((p) => (
            <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
              <div class="flex items-center justify-between gap-2">
                <h3 class="font-bold text-polla-blue">{p.name}</h3>
                <span class="text-sm font-semibold text-gray-700">{formatMoney(p.entry_amount)}</span>
              </div>
              <p class="mt-1 text-xs text-gray-400">por {p.creator?.username ?? '—'} · {p.member_count} jugadores</p>
              <div class="mt-3 flex items-center justify-between gap-2">
                <a href={`/polla/${p.id}`} class="text-sm font-semibold text-polla-blue hover:underline">Ver →</a>
                <form method="POST" action="/api/polls/join">
                  <input type="hidden" name="poll_id" value={p.id} />
                  <button class="rounded-lg bg-polla-blue px-4 py-1.5 text-sm font-semibold text-white transition hover:brightness-110">
                    Unirme
                  </button>
                </form>
              </div>
            </div>
          ))}
        </div>
      )}
    </section>
  )}
</Layout>
