---
import Layout from '../../layouts/Layout.astro';
import { isOpen, formatDate, statusLabel, pointsBadge, pot, formatMoney, dayKey, distinctDays, todayKey, type Match, type Prediction, type Poll, getTeamFlagUrl } from '../../lib/helpers';

const { supabase, user, profile } = Astro.locals;
if (!user) return Astro.redirect('/login?msg=Inicia sesión para ver la polla');
const isAdmin = profile?.role === 'admin';

const { id } = Astro.params;
const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');

// --- Polla + creador ---
const { data: pollData } = await supabase
  .from('polls')
  .select('*, creator:profiles!created_by(username)')
  .eq('id', id)
  .single();
if (!pollData) return Astro.redirect('/?error=' + encodeURIComponent('Polla no encontrada.'));
const poll = pollData as Poll & { creator: { username: string } | null };
const isOwner = poll.created_by === user.id;

// --- Miembros ---
const { data: memberData } = await supabase
  .from('poll_members')
  .select('user_id, paid, profiles(username)')
  .eq('poll_id', id);
const members = (memberData as any[]) ?? [];
const memberCount = members.length;
const myMembership = members.find((m) => m.user_id === user.id);
const isMember = !!myMembership;
const myPaid = myMembership?.paid === true;
const boteTotal = pot(poll.entry_amount, memberCount);

// --- Partidos de la polla ---
const { data: pmData } = await supabase
  .from('poll_matches')
  .select('matches(*)')
  .eq('poll_id', id);
const matches = ((pmData as any[]) ?? [])
  .map((r) => r.matches as Match)
  .filter(Boolean)
  .sort((a, b) => new Date(a.match_date).getTime() - new Date(b.match_date).getTime());

const finishedMatches = matches.filter((m) => m.status === 'finished');
const allFinished = matches.length > 0 && finishedMatches.length === matches.length;

// Partidos que ya tienen un resultado para puntuar: finalizados + en vivo con marcador.
// Los en vivo cuentan de forma PROVISIONAL (cambian con cada sync).
const scoredMatches = matches.filter(
  (m) => m.status === 'finished' || (m.status === 'live' && m.home_score != null && m.away_score != null)
);
const hasLive = scoredMatches.some((m) => m.status === 'live');

// Días distintos (UTC-5) para el filtro del desplegable.
const matchDays = distinctDays(matches.map((m) => m.match_date));
// Por defecto el filtro arranca en el día de hoy si tiene partidos; si no, en "todos".
const today = todayKey();
const defaultDay = matchDays.some((d) => d.key === today) ? today : 'all';

// --- Pronósticos de la polla (para ranking y los propios) ---
const { data: predData } = await supabase
  .from('predictions')
  .select('user_id, match_id, home_score, away_score, points_earned, profiles(username)')
  .eq('poll_id', id);
const allPreds = (predData as any[]) ?? [];

// Mis pronósticos indexados por match_id.
const myPreds = new Map<string, Prediction>();
for (const p of allPreds) if (p.user_id === user.id) myPreds.set(p.match_id, p as Prediction);

// Pronósticos visibles por jugador (la RLS ya oculta los de partidos aún abiertos de otros).
const predsByUser = new Map<string, Map<string, { h: number; a: number; pts: number }>>();
for (const p of allPreds) {
  if (!predsByUser.has(p.user_id)) predsByUser.set(p.user_id, new Map());
  predsByUser.get(p.user_id)!.set(p.match_id, { h: p.home_score, a: p.away_score, pts: p.points_earned });
}

// --- Ranking: sumar puntos por jugador sobre un conjunto de partidos ---
type Row = { user_id: string; username: string; total_points: number; correct_exact: number; total_predictions: number };
function computeRanking(matchIds: Set<string>): Row[] {
  const acc = new Map<string, Row>();
  // Inicializar con todos los miembros (aunque no hayan pronosticado).
  for (const mem of members) {
    acc.set(mem.user_id, {
      user_id: mem.user_id,
      username: mem.profiles?.username ?? '—',
      total_points: 0,
      correct_exact: 0,
      total_predictions: 0,
    });
  }
  for (const p of allPreds) {
    if (!matchIds.has(p.match_id)) continue;
    const row = acc.get(p.user_id);
    if (!row) continue;
    row.total_points += p.points_earned;
    if (p.points_earned === 5) row.correct_exact++;
    row.total_predictions++;
  }
  return [...acc.values()].sort(
    (a, b) => b.total_points - a.total_points || b.correct_exact - a.correct_exact
  );
}

// Ranking de la polla: cuenta finalizados + en vivo (puntos provisionales).
const finishedIds = new Set(finishedMatches.map((m) => m.id));
const countedIds = new Set(scoredMatches.map((m) => m.id));
const ranking = computeRanking(countedIds);

// --- Probabilidad de ganar (simulación Monte Carlo sobre partidos pendientes) ---
// Usa los pronósticos ACTUALES de cada miembro; si no pronosticó, suma 0 en ese partido.
const pendingMatches = matches.filter((m) => m.status !== 'finished');
const hasPending = pendingMatches.length > 0;
const winPct = new Map<string, number>();

if (hasPending) {
  // Pronóstico actual por (partido, usuario).
  const predByMatch = new Map<string, Map<string, { h: number; a: number }>>();
  for (const p of allPreds) {
    if (!predByMatch.has(p.match_id)) predByMatch.set(p.match_id, new Map());
    predByMatch.get(p.match_id)!.set(p.user_id, { h: p.home_score, a: p.away_score });
  }

  // ¿El partido sigue abierto? Si lo está, quien no pronosticó aún puede hacerlo,
  // así que no se le congela (se simula también una predicción suya).
  const openByMatch = new Map(pendingMatches.map((m) => [m.id, isOpen(m)]));

  // Puntos de un pronóstico vs un resultado (misma fórmula que la BD).
  const pts = (ph: number, pa: number, ah: number, aa: number): number => {
    if (ph === ah && pa === aa) return 5;
    if (ph - pa === ah - aa) return 3;
    if (Math.sign(ph - pa) === Math.sign(ah - aa)) return 2;
    return 0;
  };

  // Goles ~ Poisson(λ) por equipo (marcadores de fútbol realistas).
  const poisson = (lambda: number): number => {
    const L = Math.exp(-lambda);
    let k = 0, p = 1;
    do { k++; p *= Math.random(); } while (p > L);
    return k - 1;
  };

  const N = 10000;
  const LAMBDA = 1.35;
  // Base = solo partidos finalizados. Los partidos en vivo y próximos se simulan
  // como pendientes, así que NO se incluyen aquí (evita contarlos dos veces).
  const base = new Map(ranking.map((r) => [r.user_id, { pts: 0, exact: 0 }]));
  for (const p of allPreds) {
    if (!finishedIds.has(p.match_id)) continue;
    const b = base.get(p.user_id);
    if (b) { b.pts += p.points_earned; if (p.points_earned === 5) b.exact++; }
  }
  const credit = new Map(ranking.map((r) => [r.user_id, 0]));

  for (let s = 0; s < N; s++) {
    const fp = new Map<string, number>();
    const fe = new Map<string, number>();
    for (const r of ranking) {
      const b = base.get(r.user_id)!;
      fp.set(r.user_id, b.pts);
      fe.set(r.user_id, b.exact);
    }
    for (const m of pendingMatches) {
      const ah = poisson(LAMBDA);
      const aa = poisson(LAMBDA);
      const preds = predByMatch.get(m.id);
      const open = openByMatch.get(m.id);
      for (const r of ranking) {
        let pr = preds?.get(r.user_id);
        if (!pr) {
          if (!open) continue; // partido cerrado sin pronóstico => 0 puntos
          pr = { h: poisson(LAMBDA), a: poisson(LAMBDA) }; // abierto: aún puede pronosticar
        }
        const g = pts(pr.h, pr.a, ah, aa);
        fp.set(r.user_id, fp.get(r.user_id)! + g);
        if (g === 5) fe.set(r.user_id, fe.get(r.user_id)! + 1);
      }
    }
    // Ganador(es) de la simulación: más puntos, desempate por exactos.
    let bestP = -1, bestE = -1;
    for (const r of ranking) {
      const p = fp.get(r.user_id)!, e = fe.get(r.user_id)!;
      if (p > bestP || (p === bestP && e > bestE)) { bestP = p; bestE = e; }
    }
    const winners = ranking.filter((r) => fp.get(r.user_id) === bestP && fe.get(r.user_id) === bestE);
    const share = 1 / winners.length;
    for (const w of winners) credit.set(w.user_id, credit.get(w.user_id)! + share);
  }

  for (const r of ranking) winPct.set(r.user_id, (credit.get(r.user_id)! / N) * 100);
}

// Formatea el porcentaje: 0%, <1% o redondeado.
const fmtPct = (v: number | undefined): string => {
  if (v === undefined) return '—';
  if (v === 0) return '0%';
  if (v < 1) return '<1%';
  return Math.round(v) + '%';
};

const anyOpen = matches.some((m) => isOpen(m));
const medal = (i: number) => (i === 0 ? '🥇' : i === 1 ? '🥈' : i === 2 ? '🥉' : `${i + 1}`);
---

<Layout title={`${poll.name} · Polla Cachorraos`}>
  <a href="/" class="text-sm font-semibold text-polla-blue hover:underline">← Volver al inicio</a>

  <div class="mt-2 flex flex-wrap items-start justify-between gap-3">
    <div>
      <h1 class="text-2xl font-extrabold text-polla-blue">{poll.name}</h1>
      <p class="mt-1 text-sm text-gray-500">
        Creada por {poll.creator?.username ?? '—'} · {matches.length} partidos
      </p>
    </div>
    {isOwner && (
      <form method="POST" action="/api/polls/delete" onsubmit="return confirm('¿Eliminar esta polla? Se borran sus pronósticos.');">
        <input type="hidden" name="poll_id" value={poll.id} />
        <button class="rounded-lg border border-red-300 px-3 py-1.5 text-sm font-medium text-red-600 transition hover:bg-red-50">
          Eliminar
        </button>
      </form>
    )}
  </div>

  <div class="mt-4 grid gap-4 sm:grid-cols-3">
    <div class="card p-5">
      <p class="text-sm text-gray-500">Monto por persona</p>
      <p class="mt-1 text-2xl font-black text-polla-blue">{formatMoney(poll.entry_amount)}</p>
    </div>
    <div class="card p-5">
      <p class="text-sm text-gray-500">Participantes</p>
      <p class="mt-1 text-2xl font-black text-azul-real">{memberCount}</p>
    </div>
    <div class="bg-brand rounded-2xl p-5 text-white shadow-lg shadow-marino/20">
      <p class="text-sm text-white/80">Bote total 🏆</p>
      <p class="mt-1 text-2xl font-black text-polla-gold">{formatMoney(boteTotal)}</p>
    </div>
  </div>

  {saved && <p class="mt-4 rounded-lg bg-polla-green-light px-4 py-3 text-sm text-polla-green">✅ {saved === '1' ? 'Pronósticos guardados.' : saved}</p>}
  {error && <p class="mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{error}</p>}

  {!isMember && (
    <div class="mt-6 rounded-xl border border-polla-blue/30 bg-polla-blue-light p-5 text-center">
      <p class="text-sm text-gray-700">Aún no participas en esta polla.</p>
      <form method="POST" action="/api/polls/join" class="mt-3">
        <input type="hidden" name="poll_id" value={poll.id} />
        <button class="rounded-lg bg-polla-blue px-6 py-2.5 text-sm font-semibold text-white transition hover:brightness-110">
          Unirme a la polla
        </button>
      </form>
    </div>
  )}

  {/* --- Aviso de pago (Yape del chef Gabriel) --- */}
  {isMember && (
    <div class="mt-8 flex flex-wrap items-center justify-between gap-3 rounded-xl border border-polla-gold/40 bg-yellow-50 px-4 py-3">
      <p class="text-sm font-medium text-gray-700">
        💸 Recuerda hacer tu paguito con el chef Gabriel
        {myPaid ? (
          <span class="ml-2 rounded-full bg-polla-green-light px-2 py-0.5 text-xs font-semibold text-polla-green">Tu pago: pagado ✓</span>
        ) : (
          <span class="ml-2 rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500">Tu pago: pendiente</span>
        )}
      </p>
      <button
        type="button" id="yape-btn"
        class="inline-flex items-center gap-2 rounded-lg bg-polla-blue px-3 py-1.5 text-sm font-semibold text-white transition hover:brightness-110"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-4 w-4" aria-hidden="true">
          <path d="M3 3h8v8H3V3zm2 2v4h4V5H5zm8-2h8v8h-8V3zm2 2v4h4V5h-4zM3 13h8v8H3v-8zm2 2v4h4v-4H5zm13-2h3v2h-3v-2zm-5 0h3v3h-2v-1h-1v-2zm5 3h3v5h-5v-2h2v-1h-2v-1h2v-1zm-5 2h2v3h-2v-3z"/>
        </svg>
        Pagar con Yape
      </button>
    </div>
  )}

  {isMember && (
    <dialog id="yape-modal" class="fixed left-1/2 top-1/2 m-0 -translate-x-1/2 -translate-y-1/2 rounded-2xl p-0 backdrop:bg-black/50">
      <div class="w-[26rem] max-w-[92vw] p-6 text-center">
        <h3 class="text-lg font-bold text-polla-blue">Yape · Chef Gabriel</h3>
        <p class="mt-1 text-sm text-gray-500">Escanea el código para hacer tu pago.</p>
        <img src="/yape-gabriel.png" alt="QR de Yape del chef Gabriel" class="mx-auto mt-4 w-80 max-w-full rounded-lg border border-gray-200" />
        <button id="yape-close" type="button" class="mt-5 w-full rounded-lg bg-gray-100 px-4 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-200">
          Cerrar
        </button>
      </div>
    </dialog>
  )}

  {/* --- Pronósticos (solo miembros) --- */}
  {isMember && (
    <section class="mt-6">
      <div class="flex flex-wrap items-start justify-between gap-2">
        <div>
          <h2 class="text-lg font-bold text-gray-800">Mis pronósticos</h2>
          <p class="mt-1 text-sm text-gray-500">El pronóstico se cierra 5 minutos antes de cada partido.</p>
        </div>
        {matchDays.length > 1 && (
          <select
            id="day-filter"
            class="rounded-lg border border-gray-300 bg-white px-3 py-1.5 text-sm font-medium text-gray-700 shadow-sm focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30"
          >
            <option value="all" selected={defaultDay === 'all'}>Todos los días</option>
            {matchDays.map((d) => (
              <option value={d.key} selected={defaultDay === d.key}>{d.label}</option>
            ))}
          </select>
        )}
      </div>

      <form method="POST" action="/api/predictions-batch" class="mt-3 space-y-3">
        <input type="hidden" name="poll_id" value={poll.id} />
        {matches.map((m) => {
          const pred = myPreds.get(m.id);
          const open = isOpen(m);
          const finished = m.status === 'finished';
          const badge = pred && finished ? pointsBadge(pred.points_earned) : null;
          const homeFlag = getTeamFlagUrl(m.home_team);
          const awayFlag = getTeamFlagUrl(m.away_team);
          return (
            <div class="match-card rounded-xl border border-gray-200 bg-white p-4 shadow-sm" data-day={dayKey(m.match_date)}>
              <div class="flex flex-wrap items-center justify-between gap-2">
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500">
                  {statusLabel[m.status]} · {formatDate(m.match_date)}
                </span>
                <span class="save-status text-xs font-semibold" data-status-id={m.id}></span>
                {finished && <span class="text-sm font-bold text-gray-700">Resultado: {m.home_score} – {m.away_score}</span>}
                {badge && <span class={`rounded-full px-2 py-0.5 text-xs font-semibold ${badge.classes}`}>{badge.label}</span>}
                {!open && !finished && <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-400">Cerrado</span>}
              </div>
              <div class="mt-3 flex flex-wrap items-center justify-center gap-3 sm:justify-between">
                <div class="flex flex-1 items-center justify-end gap-2 text-right font-semibold min-w-[120px]">
                  <span>{m.home_team}</span>
                  {homeFlag && <img src={homeFlag} class="h-4 w-6 rounded border border-gray-200 object-cover shadow-sm" alt="" />}
                </div>
                <input
                  type="number" name={`home_${m.id}`} min="0" max="99"
                  value={pred?.home_score ?? ''}
                  disabled={!open}
                  class="w-14 rounded-lg border border-gray-300 px-2 py-2 text-center text-lg font-bold focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30 disabled:bg-gray-100 disabled:text-gray-500"
                  placeholder="-"
                />
                <span class="font-bold text-gray-400">:</span>
                <input
                  type="number" name={`away_${m.id}`} min="0" max="99"
                  value={pred?.away_score ?? ''}
                  disabled={!open}
                  class="w-14 rounded-lg border border-gray-300 px-2 py-2 text-center text-lg font-bold focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30 disabled:bg-gray-100 disabled:text-gray-500"
                  placeholder="-"
                />
                <div class="flex flex-1 items-center gap-2 font-semibold min-w-[120px]">
                  {awayFlag && <img src={awayFlag} class="h-4 w-6 rounded border border-gray-200 object-cover shadow-sm" alt="" />}
                  <span>{m.away_team}</span>
                </div>
              </div>
            </div>
          );
        })}

        {anyOpen ? (
          <button class="w-full rounded-lg bg-polla-green px-4 py-3 text-sm font-semibold text-white transition hover:brightness-110">
            Guardar pronósticos
          </button>
        ) : (
          <p class="rounded-lg bg-gray-100 px-4 py-3 text-center text-sm font-medium text-gray-400">
            Todos los pronósticos de esta polla están cerrados.
          </p>
        )}
      </form>
    </section>
  )}

  {/* --- Tabla de la polla (acumulada) --- */}
  <section class="mt-10">
    <div class="flex flex-wrap items-center justify-between gap-2">
      <h2 class="text-lg font-bold text-gray-800">Tabla de la polla</h2>
      <form method="POST" action="/api/sync">
        <input type="hidden" name="poll_id" value={poll.id} />
        <button class="inline-flex items-center gap-1 rounded-lg border border-polla-blue/40 bg-polla-blue-light px-3 py-1 text-sm font-semibold text-polla-blue transition hover:brightness-105">
          ⟳ Actualizar resultados
        </button>
      </form>
    </div>

    <div class="mt-1 flex flex-wrap items-center justify-between gap-2">
      <p class="text-sm text-gray-500">
        Puntos sobre {scoredMatches.length} partidos con resultado{hasLive ? ' (incluye en vivo, provisionales)' : ''} · desempate por exactos.
        {hasPending && ' El % es la probabilidad estimada de quedar 1ro según los pronósticos actuales (0% = ya no puede ganar).'}
      </p>
      {hasLive && (
        <span class="inline-flex items-center gap-1 rounded-full bg-red-50 px-3 py-1 text-xs font-bold text-red-600">
          <span class="inline-block h-2 w-2 animate-pulse rounded-full bg-red-500"></span> En vivo
        </span>
      )}
      {allFinished && ranking.length > 0 && (
        <span class="rounded-full bg-polla-gold px-3 py-1 text-xs font-bold text-polla-blue">
          🏆 Ganador: {ranking[0].username}
        </span>
      )}
    </div>

    <div class="mt-4 overflow-x-auto rounded-2xl border border-gray-200 bg-white shadow-sm">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-brand text-left text-white">
            <th class="px-4 py-3">#</th>
            <th class="px-4 py-3">Jugador</th>
            <th class="px-4 py-3 text-center">Pts</th>
            <th class="px-4 py-3 text-center" title="Resultados exactos">🎯</th>
            <th class="px-4 py-3 text-center">Pron.</th>
            {hasPending && <th class="px-4 py-3 text-center" title="Probabilidad estimada de quedar 1ro">% ganar</th>}
            <th class="px-4 py-3 text-center">Ver</th>
          </tr>
        </thead>
        <tbody>
          {ranking.length === 0 && (
            <tr><td colspan={hasPending ? 7 : 6} class="px-4 py-8 text-center text-gray-400">Aún no hay participantes.</td></tr>
          )}
          {ranking.map((r, i) => {
            const pct = winPct.get(r.user_id);
            return (
            <tr class={`border-t border-gray-100 ${r.user_id === user.id ? 'bg-polla-green-light/60 font-semibold' : i % 2 ? 'bg-gray-50/50' : ''}`}>
              <td class="px-4 py-3 text-lg">{medal(i)}</td>
              <td class="px-4 py-3">
                {r.username}
                {r.user_id === user.id && <span class="ml-2 rounded-full bg-polla-green px-2 py-0.5 text-xs text-white">tú</span>}
              </td>
              <td class="px-4 py-3 text-center text-lg font-extrabold text-polla-blue">{r.total_points}</td>
              <td class="px-4 py-3 text-center">{r.correct_exact}</td>
              <td class="px-4 py-3 text-center text-gray-500">{r.total_predictions}</td>
              {hasPending && (
                <td class={`px-4 py-3 text-center font-semibold ${pct === 0 ? 'text-gray-400' : pct && pct >= 50 ? 'text-polla-green' : 'text-gray-700'}`}>
                  {fmtPct(pct)}
                </td>
              )}
              <td class="px-4 py-3 text-center">
                <button type="button" data-preds={r.user_id} title={`Ver pronósticos de ${r.username}`} aria-label="Ver pronósticos"
                  class="text-base text-gray-400 transition hover:text-polla-blue">👁</button>
              </td>
            </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    {/* Modales: pronósticos de cada jugador en esta polla */}
    {ranking.map((r) => (
      <dialog id={`preds-${r.user_id}`} class="fixed left-1/2 top-1/2 m-0 -translate-x-1/2 -translate-y-1/2 rounded-2xl p-0 backdrop:bg-black/50">
        <div class="w-[32rem] max-w-[92vw] p-6">
          <div class="flex items-center justify-between gap-2">
            <h3 class="text-lg font-bold text-polla-blue">Pronósticos de {r.username}</h3>
            <button type="button" class="preds-close rounded-lg bg-gray-100 px-3 py-1 text-sm font-semibold text-gray-600 transition hover:bg-gray-200">✕</button>
          </div>
          <div class="mt-4 overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="text-left text-gray-400">
                  <th class="py-1 pr-2">Partido</th>
                  <th class="py-1 text-center">Pron.</th>
                  <th class="py-1 text-center">Resultado</th>
                  <th class="py-1 text-center">Pts</th>
                </tr>
              </thead>
              <tbody>
                {matches.map((m) => {
                  const pr = predsByUser.get(r.user_id)?.get(m.id);
                  const finished = m.status === 'finished';
                  const hidden = !pr && isOpen(m) && r.user_id !== user.id && !isAdmin;
                  const homeFlag = getTeamFlagUrl(m.home_team);
                  const awayFlag = getTeamFlagUrl(m.away_team);
                  return (
                    <tr class="border-t border-gray-100">
                      <td class="py-2 pr-2">
                        <div class="flex flex-wrap items-center gap-1.5">
                          {homeFlag && <img src={homeFlag} class="h-3.5 w-5 rounded border border-gray-100 object-cover shadow-xs" alt="" />}
                          <span class="font-medium">{m.home_team}</span>
                          <span class="text-gray-400 font-normal">vs</span>
                          {awayFlag && <img src={awayFlag} class="h-3.5 w-5 rounded border border-gray-100 object-cover shadow-xs" alt="" />}
                          <span class="font-medium">{m.away_team}</span>
                        </div>
                      </td>
                      <td class="py-2 text-center font-semibold">
                        {pr ? `${pr.h} - ${pr.a}` : <span class="text-gray-400">{hidden ? '🔒 oculto' : '—'}</span>}
                      </td>
                      <td class="py-2 text-center text-gray-600">{finished ? `${m.home_score} - ${m.away_score}` : '—'}</td>
                      <td class="py-2 text-center">{pr && finished ? <span class="font-semibold text-polla-blue">{pr.pts}</span> : '—'}</td>
                    </tr>
                  );
                })}
              </tbody>
            </table>
          </div>
          <button type="button" class="preds-close mt-5 w-full rounded-lg bg-gray-100 px-4 py-2.5 text-sm font-semibold text-gray-700 transition hover:bg-gray-200">
            Cerrar
          </button>
        </div>
      </dialog>
    ))}
  </section>

  <script is:inline>
    (() => {
      const btn = document.getElementById('yape-btn');
      const modal = document.getElementById('yape-modal');
      const close = document.getElementById('yape-close');
      if (!btn || !modal) return;
      btn.addEventListener('click', () => modal.showModal());
      close && close.addEventListener('click', () => modal.close());
      // Cerrar al hacer click fuera del contenido.
      modal.addEventListener('click', (e) => { if (e.target === modal) modal.close(); });
    })();

    // Filtro de partidos por día (solo afecta las tarjetas de pronóstico).
    (() => {
      const filter = document.getElementById('day-filter');
      const cards = document.querySelectorAll('.match-card');

      function filterCards() {
        const day = filter ? filter.value : 'all';
        cards.forEach((c) => {
          const show = day === 'all' || c.getAttribute('data-day') === day;
          c.style.display = show ? '' : 'none';
        });
      }

      if (filter) filter.addEventListener('change', filterCards);
      filterCards();
    })();

    // Modales de pronósticos por jugador.
    (() => {
      document.querySelectorAll('[data-preds]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const d = document.getElementById('preds-' + btn.getAttribute('data-preds'));
          if (d && d.showModal) d.showModal();
        });
      });
      document.querySelectorAll('dialog[id^="preds-"]').forEach((d) => {
        d.querySelectorAll('.preds-close').forEach((c) => c.addEventListener('click', () => d.close()));
        d.addEventListener('click', (e) => { if (e.target === d) d.close(); });
      });
    })();

    // Auto-save de pronósticos
    (() => {
      const form = document.querySelector('form[action="/api/predictions-batch"]');
      if (!form) return;

      const pollIdInput = form.querySelector('input[name="poll_id"]');
      if (!pollIdInput) return;
      const pollId = pollIdInput.value;

      // Ocultar botón de guardar y agregar nota de guardado automático
      const saveBtn = form.querySelector('button:not([type="button"])');
      if (saveBtn) {
        saveBtn.style.display = 'none';
        const note = document.createElement('p');
        note.className = 'text-center text-xs text-gray-400 font-medium mt-2';
        note.textContent = '⚡ Los pronósticos se guardan automáticamente al escribir.';
        form.appendChild(note);
      }

      // Escuchar cambios en los inputs
      form.addEventListener('input', async (e) => {
        const target = e.target;
        if (!target || target.tagName !== 'INPUT' || target.type !== 'number') return;

        const name = target.name;
        const matchId = name.split('_')[1];
        if (!matchId) return;

        const homeInput = form.querySelector(`input[name="home_${matchId}"]`);
        const awayInput = form.querySelector(`input[name="away_${matchId}"]`);
        const statusSpan = document.querySelector(`.save-status[data-status-id="${matchId}"]`);

        if (!homeInput || !awayInput) return;

        const homeVal = homeInput.value.trim();
        const awayVal = awayInput.value.trim();

        // Solo guardar si ambos están llenos
        if (homeVal === '' || awayVal === '') {
          if (statusSpan) statusSpan.textContent = '';
          return;
        }

        const homeNum = parseInt(homeVal, 10);
        const awayNum = parseInt(awayVal, 10);
        if (isNaN(homeNum) || isNaN(awayNum) || homeNum < 0 || awayNum < 0) {
          if (statusSpan) {
            statusSpan.textContent = 'Valor inválido';
            statusSpan.className = 'save-status text-xs font-semibold text-red-500';
          }
          return;
        }

        if (statusSpan) {
          statusSpan.textContent = 'Guardando...';
          statusSpan.className = 'save-status text-xs font-semibold text-polla-blue animate-pulse';
        }

        const formData = new FormData();
        formData.append('poll_id', pollId);
        formData.append(`home_${matchId}`, homeVal);
        formData.append(`away_${matchId}`, awayVal);

        try {
          const res = await fetch('/api/predictions-batch', {
            method: 'POST',
            headers: {
              'Accept': 'application/json'
            },
            body: formData
          });

          if (res.ok) {
            if (statusSpan) {
              statusSpan.textContent = '✓ Guardado';
              statusSpan.className = 'save-status text-xs font-semibold text-polla-green';
            }
          } else {
            const data = await res.json().catch(() => ({}));
            if (statusSpan) {
              statusSpan.textContent = `✗ ${data.error || 'Error'}`;
              statusSpan.className = 'save-status text-xs font-semibold text-red-500';
            }
          }
        } catch (err) {
          if (statusSpan) {
            statusSpan.textContent = '✗ Error de red';
            statusSpan.className = 'save-status text-xs font-semibold text-red-500';
          }
        }
      });
    })();
  </script>

  {hasLive && (
    <script is:inline>
      // Auto-refresco mientras hay partidos en vivo: recarga cada 60s para mostrar
      // los puntos provisionales actualizados, sin interrumpir si estás editando.
      (() => {
        let dirty = false;
        const form = document.querySelector('form[action="/api/predictions-batch"]');
        if (form) form.addEventListener('input', () => { dirty = true; });
        setInterval(() => {
          const active = document.activeElement;
          const editing = active && active.tagName === 'INPUT';
          const modalOpen = document.querySelector('dialog[open]');
          if (dirty || editing || modalOpen) return; // no interrumpir al usuario
          location.reload();
        }, 60000);
      })();
    </script>
  )}
</Layout>
