---
import Layout from '../../layouts/Layout.astro';
import { formatDate, statusLabel, isOpen, isoToLocalInput, type Match } from '../../lib/helpers';

const { supabase, user, profile } = Astro.locals;
if (!user) return Astro.redirect('/login');
if (profile?.role !== 'admin') return Astro.redirect('/');

const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');

const { data } = await supabase.from('matches').select('*').order('match_date', { ascending: true });
const matches = (data as Match[]) ?? [];

const pending = matches.filter((m) => m.status !== 'finished').length;

// Usuarios registrados (para designar tesorero)
const { data: profData } = await supabase
  .from('profiles')
  .select('id, username, role')
  .order('username', { ascending: true });
const profiles = (profData as { id: string; username: string; role: string }[]) ?? [];

// valor por defecto para datetime-local (ahora + 2h, en UTC-5)
const def = isoToLocalInput(new Date(Date.now() + 2 * 60 * 60 * 1000).toISOString());
---

<Layout title="Admin · Polla Mundialista">
  <h1 class="text-2xl font-extrabold text-polla-blue">Panel de administrador</h1>

  {saved && <p class="mt-4 rounded-lg bg-polla-green-light px-4 py-3 text-sm text-polla-green">✅ {saved}</p>}
  {error && <p class="mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{error}</p>}

  <div class="mt-4 grid grid-cols-2 gap-3 sm:grid-cols-3">
    <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-polla-blue">{matches.length}</p>
      <p class="text-xs text-gray-500">Partidos</p>
    </div>
    <div class="rounded-xl border border-gray-200 bg-white p-4 text-center shadow-sm">
      <p class="text-2xl font-extrabold text-yellow-600">{pending}</p>
      <p class="text-xs text-gray-500">Sin resultado</p>
    </div>
  </div>

  <!-- Sincronizar fixture desde la API -->
  <section class="mt-8 rounded-2xl border border-polla-blue/30 bg-polla-blue-light/40 p-6 shadow-sm">
    <h2 class="mb-1 text-lg font-bold text-polla-blue">Sincronizar fixture automáticamente</h2>
    <p class="mb-4 text-sm text-gray-600">
      Trae todos los partidos del Mundial desde football-data.org y actualiza los resultados
      de los que ya se jugaron (recalculando los puntos). Puedes repetirlo sin duplicar partidos.
    </p>
    <form method="POST" action="/api/admin/sync">
      <button class="rounded-lg bg-polla-blue px-5 py-2.5 font-semibold text-white transition hover:brightness-110">
        ⟳ Sincronizar fixture
      </button>
    </form>
  </section>

  <!-- Gestionar tesorero -->
  <section class="mt-8 rounded-2xl border border-polla-gold/40 bg-yellow-50/60 p-6 shadow-sm">
    <h2 class="mb-1 text-lg font-bold text-polla-blue">Gestionar tesorero</h2>
    <p class="mb-4 text-sm text-gray-600">
      El tesorero marca quién ya pagó. Solo puede haber <strong>uno a la vez</strong>: al asignarlo a
      alguien, se le retira al anterior.
    </p>
    <div class="divide-y divide-gray-100 overflow-hidden rounded-xl border border-gray-200 bg-white">
      {profiles.map((p) => (
        <div class="flex items-center justify-between gap-3 px-4 py-2.5">
          <span class="flex items-center gap-2 text-sm">
            <span class="font-medium">{p.username}</span>
            {p.role === 'admin' && <span class="rounded-full bg-polla-blue px-2 py-0.5 text-xs font-semibold text-white">admin</span>}
            {p.role === 'tesorero' && <span class="rounded-full bg-polla-gold px-2 py-0.5 text-xs font-semibold text-polla-blue">tesorero</span>}
          </span>
          {p.role !== 'admin' && (
            p.role === 'tesorero' ? (
              <form method="POST" action="/api/admin/set-role">
                <input type="hidden" name="user_id" value={p.id} />
                <input type="hidden" name="action" value="revoke" />
                <button class="rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 transition hover:bg-gray-50">
                  Quitar tesorero
                </button>
              </form>
            ) : (
              <form method="POST" action="/api/admin/set-role">
                <input type="hidden" name="user_id" value={p.id} />
                <input type="hidden" name="action" value="grant" />
                <button class="rounded-lg bg-polla-gold px-3 py-1.5 text-sm font-semibold text-polla-blue transition hover:brightness-95">
                  Hacer tesorero
                </button>
              </form>
            )
          )}
        </div>
      ))}
    </div>
  </section>

  <!-- Crear partido -->
  <section class="mt-8 rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
    <h2 class="mb-4 text-lg font-bold text-gray-800">Crear partido</h2>
    <form method="POST" action="/api/admin/match" class="grid gap-3 sm:grid-cols-2">
      <input name="home_team" required placeholder="Equipo local"
        class="rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
      <input name="away_team" required placeholder="Equipo visitante"
        class="rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
      <input name="match_date" type="datetime-local" required value={def}
        class="rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
      <input name="stage" placeholder="Fase (ej. Fase de grupos)" value="Fase de grupos"
        class="rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
      <input name="round" placeholder="Jornada (opcional)"
        class="rounded-lg border border-gray-300 px-3 py-2 focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30 sm:col-span-2" />
      <button class="rounded-lg bg-polla-green px-4 py-2.5 font-semibold text-white transition hover:brightness-110 sm:col-span-2">
        Crear partido
      </button>
    </form>
  </section>

  <!-- Registrar resultados -->
  <section class="mt-8">
    <h2 class="mb-3 text-lg font-bold text-gray-800">Partidos</h2>
    <div class="space-y-3">
      {matches.map((m) => {
        const open = isOpen(m);
        return (
        <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
          <div class="mb-2 flex flex-wrap items-center justify-between gap-2 text-sm">
            <span class="font-semibold">{m.home_team} vs {m.away_team}</span>
            <span class="flex items-center gap-2">
              {open ? (
                <span class="rounded-full bg-polla-green-light px-2 py-0.5 text-xs font-semibold text-polla-green">Pronósticos abiertos</span>
              ) : (
                <span class="rounded-full bg-gray-200 px-2 py-0.5 text-xs font-semibold text-gray-600">Pronósticos cerrados</span>
              )}
              {m.force_open === true && <span class="rounded-full bg-yellow-100 px-2 py-0.5 text-xs text-yellow-700">manual</span>}
              <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500">
                {statusLabel[m.status]} · {formatDate(m.match_date)}
              </span>
            </span>
          </div>
          <form method="POST" action="/api/admin/result" class="flex flex-wrap items-center gap-2">
            <input type="hidden" name="match_id" value={m.id} />
            <input type="number" name="home_score" min="0" max="99" value={m.home_score ?? ''} placeholder="0" required
              class="w-16 rounded-lg border border-gray-300 px-2 py-2 text-center font-bold focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
            <span class="font-bold text-gray-400">:</span>
            <input type="number" name="away_score" min="0" max="99" value={m.away_score ?? ''} placeholder="0" required
              class="w-16 rounded-lg border border-gray-300 px-2 py-2 text-center font-bold focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30" />
            <button class="rounded-lg bg-polla-blue px-4 py-2 text-sm font-semibold text-white transition hover:brightness-110">
              Registrar resultado
            </button>
          </form>

          <div class="mt-2 flex flex-wrap items-center gap-2 border-t border-gray-100 pt-2 text-sm">
            {!open ? (
              <form method="POST" action="/api/admin/toggle-open">
                <input type="hidden" name="match_id" value={m.id} />
                <input type="hidden" name="value" value="open" />
                <button class="rounded-lg bg-polla-green px-4 py-2 font-semibold text-white transition hover:brightness-110">
                  🔓 Habilitar pronósticos
                </button>
              </form>
            ) : m.force_open === true ? (
              <form method="POST" action="/api/admin/toggle-open">
                <input type="hidden" name="match_id" value={m.id} />
                <input type="hidden" name="value" value="auto" />
                <button class="rounded-lg border border-yellow-400 bg-yellow-50 px-4 py-2 font-semibold text-yellow-700 transition hover:bg-yellow-100">
                  ↩ Volver a automático
                </button>
              </form>
            ) : (
              <form method="POST" action="/api/admin/toggle-open">
                <input type="hidden" name="match_id" value={m.id} />
                <input type="hidden" name="value" value="close" />
                <button class="rounded-lg border border-gray-300 px-4 py-2 font-medium text-gray-700 transition hover:bg-gray-50">
                  🔒 Cerrar pronósticos
                </button>
              </form>
            )}
            <a href={`/admin/editar/${m.id}`} class="rounded-lg border border-gray-300 px-4 py-2 font-medium text-gray-700 transition hover:bg-gray-50">
              ✎ Editar
            </a>
            <a href={`/admin/partido/${m.id}`} class="rounded-lg border border-gray-300 px-4 py-2 font-medium text-gray-600 transition hover:bg-gray-50">
              Ver pronósticos
            </a>
            <form method="POST" action="/api/admin/match-delete"
                  onsubmit="return confirm('¿Eliminar este partido? Se borrarán también los pronósticos asociados.');">
              <input type="hidden" name="match_id" value={m.id} />
              <button class="rounded-lg border border-red-300 px-4 py-2 font-medium text-red-600 transition hover:bg-red-50">
                🗑 Eliminar
              </button>
            </form>
          </div>
        </div>
        );
      })}
    </div>
  </section>
</Layout>
