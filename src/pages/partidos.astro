---
import Layout from '../layouts/Layout.astro';
import { isOpen, formatDate, statusLabel, pointsBadge, type Match, type Prediction } from '../lib/helpers';

const { supabase, user } = Astro.locals;
if (!user) return Astro.redirect('/login?msg=Inicia sesión para ver los partidos');

const saved = Astro.url.searchParams.get('saved');
const error = Astro.url.searchParams.get('error');

const { data: matchData } = await supabase
  .from('matches')
  .select('*')
  .order('match_date', { ascending: true });
const matches = (matchData as Match[]) ?? [];

// Mis pronósticos, indexados por match_id
const { data: predData } = await supabase
  .from('predictions')
  .select('*')
  .eq('user_id', user.id);
const myPreds = new Map<string, Prediction>();
for (const p of (predData as Prediction[]) ?? []) myPreds.set(p.match_id, p);

// Agrupar por jornada/fase
const groups = new Map<string, Match[]>();
for (const m of matches) {
  const key = m.round ? `${m.stage} · ${m.round}` : m.stage;
  if (!groups.has(key)) groups.set(key, []);
  groups.get(key)!.push(m);
}
---

<Layout title="Partidos · Polla Mundialista">
  <h1 class="text-2xl font-extrabold text-polla-blue">Partidos</h1>
  <p class="mt-1 text-sm text-gray-500">
    Ingresa tu marcador. El pronóstico se cierra 5 minutos antes del inicio.
  </p>

  {saved && <p class="mt-4 rounded-lg bg-polla-green-light px-4 py-3 text-sm text-polla-green">✅ Pronóstico guardado.</p>}
  {error && <p class="mt-4 rounded-lg bg-red-50 px-4 py-3 text-sm text-red-700">{error}</p>}

  {matches.length === 0 && (
    <p class="mt-6 rounded-xl border border-dashed border-gray-300 bg-white p-6 text-center text-gray-500">
      Todavía no hay partidos cargados.
    </p>
  )}

  {[...groups.entries()].map(([groupName, groupMatches]) => (
    <section class="mt-8">
      <h2 class="mb-3 text-sm font-bold uppercase tracking-wide text-gray-400">{groupName}</h2>
      <div class="space-y-3">
        {groupMatches.map((m) => {
          const pred = myPreds.get(m.id);
          const open = isOpen(m);
          const finished = m.status === 'finished';
          const badge = pred && finished ? pointsBadge(pred.points_earned) : null;
          return (
            <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
              <div class="flex flex-wrap items-center justify-between gap-2">
                <span class="rounded-full bg-gray-100 px-2 py-0.5 text-xs text-gray-500">
                  {statusLabel[m.status]} · {formatDate(m.match_date)}
                </span>
                {finished && (
                  <span class="text-sm font-bold text-gray-700">
                    Resultado: {m.home_score} – {m.away_score}
                  </span>
                )}
                {badge && <span class={`rounded-full px-2 py-0.5 text-xs font-semibold ${badge.classes}`}>{badge.label}</span>}
              </div>

              <form method="POST" action="/api/predictions" class="mt-3 flex flex-wrap items-center justify-center gap-3 sm:justify-between">
                <input type="hidden" name="match_id" value={m.id} />
                <div class="flex flex-1 items-center justify-end gap-2 text-right font-semibold min-w-[120px]">
                  {m.home_team}
                </div>
                <input
                  type="number" name="home_score" min="0" max="99"
                  value={pred?.home_score ?? ''}
                  disabled={!open}
                  class="w-14 rounded-lg border border-gray-300 px-2 py-2 text-center text-lg font-bold focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30 disabled:bg-gray-100 disabled:text-gray-500"
                  placeholder="-"
                />
                <span class="font-bold text-gray-400">:</span>
                <input
                  type="number" name="away_score" min="0" max="99"
                  value={pred?.away_score ?? ''}
                  disabled={!open}
                  class="w-14 rounded-lg border border-gray-300 px-2 py-2 text-center text-lg font-bold focus:border-polla-blue focus:outline-none focus:ring-2 focus:ring-polla-blue/30 disabled:bg-gray-100 disabled:text-gray-500"
                  placeholder="-"
                />
                <div class="flex flex-1 items-center gap-2 font-semibold min-w-[120px]">
                  {m.away_team}
                </div>
                {open ? (
                  <button class="rounded-lg bg-polla-green px-4 py-2 text-sm font-semibold text-white transition hover:brightness-110">
                    Guardar
                  </button>
                ) : (
                  <span class="rounded-lg bg-gray-100 px-4 py-2 text-sm font-medium text-gray-400">Cerrado</span>
                )}
              </form>
            </div>
          );
        })}
      </div>
    </section>
  ))}
</Layout>
