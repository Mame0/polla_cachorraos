---
import '../styles/global.css';

interface Props {
  title?: string;
}
const { title = 'Polla Mundialista' } = Astro.props;

const { user, profile } = Astro.locals;
const isAdmin = profile?.role === 'admin';
const isTesorero = profile?.role === 'tesorero';
const path = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Pollas' },
  { href: '/mis-pronosticos', label: 'Mis pronósticos' },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Polla Mundialista — pronostica los partidos y compite con tus amigos" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen text-gray-800">
    <header class="bg-brand sticky top-0 z-40 text-white shadow-lg shadow-marino/20">
      <nav class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-4 py-3">
        <a href="/" class="group flex items-center gap-2 text-lg font-extrabold tracking-tight">
          <span class="grid h-9 w-9 place-items-center rounded-xl bg-white/15 text-xl ring-1 ring-white/20 transition group-hover:scale-105 group-hover:bg-white/25">⚽</span>
          <span>POLLA <span class="text-polla-gold drop-shadow-[0_1px_6px_rgba(235,255,61,0.4)]">CACHORRAOS</span></span>
        </a>

        {user && (
          <div class="flex flex-wrap items-center gap-1 text-sm">
            {navLinks.map((link) => (
              <a
                href={link.href}
                class={`rounded-md px-3 py-1.5 transition hover:bg-white/15 ${
                  path === link.href ? 'bg-white/20 font-semibold' : ''
                }`}
              >
                {link.label}
              </a>
            ))}
            {(isAdmin || isTesorero) && (
              <a
                href="/tesorero"
                class={`rounded-md px-3 py-1.5 font-semibold text-polla-gold transition hover:bg-white/15 ${
                  path.startsWith('/tesorero') ? 'bg-white/20' : ''
                }`}
              >
                Tesorero
              </a>
            )}
            {isAdmin && (
              <a
                href="/admin"
                class={`rounded-md px-3 py-1.5 font-semibold text-polla-gold transition hover:bg-white/15 ${
                  path.startsWith('/admin') ? 'bg-white/20' : ''
                }`}
              >
                Admin
              </a>
            )}
          </div>
        )}

        <div class="flex items-center gap-3 text-sm">
          {user ? (
            <>
              <span class="hidden sm:inline opacity-90">
                Hola, <strong>{profile?.username ?? 'jugador'}</strong>
              </span>
              <form method="POST" action="/api/auth/logout">
                <button class="rounded-md bg-white/15 px-3 py-1.5 font-medium transition hover:bg-white/25">
                  Salir
                </button>
              </form>
            </>
          ) : (
            <>
              <a href="/login" class="rounded-md px-3 py-1.5 transition hover:bg-white/15">Entrar</a>
              <a href="/register" class="btn-shine rounded-md bg-polla-gold px-3 py-1.5 font-semibold text-polla-blue shadow-sm transition hover:brightness-95">
                Registrarse
              </a>
            </>
          )}
        </div>
      </nav>
      <div class="neon-line h-0.5 w-full"></div>
    </header>

    <main class="mx-auto max-w-5xl px-4 py-8">
      <slot />
    </main>

    <footer class="mt-12 border-t border-marino/10 py-6 text-center text-xs text-gray-500">
      <span class="font-semibold text-marino">⚽ Polla Cachorraos</span> · Astro + Supabase
    </footer>
  </body>
</html>
