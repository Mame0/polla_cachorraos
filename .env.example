# Copia este archivo a ".env" y rellena con los datos de tu proyecto Supabase
# (Supabase Dashboard -> Project Settings -> API)

PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu-anon-public-key

# --- Sincronización del fixture (football-data.org) ---
# Token gratis: https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=tu-token-de-football-data
# Competición a sincronizar (WC = Mundial). Otras: CL, PL, PD, SA, BL1, FL1, EC...
FOOTBALL_COMPETITION=WC

# --- Solo para el script automático scripts/sync-fixture.mjs (cron) ---
# service_role key: Supabase -> Project Settings -> API (¡secreto, NO lo expongas en el cliente!)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key

# --- Cron externo (cron-job.org) ---
# Cualquier string aleatorio que uses como contraseña del endpoint /api/cron/sync
CRON_SECRET=genera-un-string-aleatorio-aqui
